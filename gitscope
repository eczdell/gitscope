_SB="" _HR=""
build_status_bar() {
    _SB=""
    _SB+="${BLD}${CYN} ${RST} ${BLD}${CYN}${REPO_NAME}${RST}"
    _SB+="${DIM} │ ${RST}${BLD}${GRN}${CUR_BR}${RST}"

    local mode_label="tree"
    (( DIFF_MODE ))  && mode_label="diff"
    (( FILES_MODE )) && mode_label="files"
    (( REPORT_MODE )) && mode_label="report"

    _SB+="${DIM} │ ${RST}${BLD}${WHT}${TOTAL}${RST}${DIM} commits${RST}"
    _SB+="${DIM} │ ${RST}${BLD}${LCY}${mode_label}${RST}"

    if [[ -n "$FILTER_TEXT" ]]; then
        _SB+="${DIM} │ ${RST}${BLD}${LGR}/${RST}${FILTER_TEXT}"
    fi

    if [[ -n "$DATE_FROM" || -n "$DATE_TO" ]]; then
        _SB+="${DIM} │ ${RST}${BLD}${LCY}📅${RST} ${DATE_FROM:-..}→${DATE_TO:-..}"
    fi

    if [[ -n "$DESCENDANT_FILTER" ]]; then
        _SB+="${DIM} │ ${RST}${BLD}${LYL}▼${RST} zoom:${DESCENDANT_FILTER:0:7}"
    fi

    if (( SHOW_ALL )); then
        _SB+="${DIM} │ ${RST}${LYL}${BLD}ALL${RST}"
    fi
    if (( SHOW_META )); then
        _SB+="${DIM} │ ${RST}${LYL}${BLD}META${RST}"
    fi
    if (( COMPACT )); then
        _SB+="${DIM} │ ${RST}${LYL}${BLD}CMP${RST}"
    fi

    local used=${#_SB}
    local fill=$((TERM_W - used))
    (( fill > 0 )) && _SB+=$(printf '%*s' $fill '')

    _SB+="${NL}"
}

build_hr() {
    local hr=""
    for _ in $(seq 1 $TERM_W); do hr+="─"; done
    _HR="${DIM}${hr}${RST}${NL}"
}

draw() {
    if (( DIFF_MODE )); then draw_diff; return; fi
    if (( FILES_MODE )); then draw_files; return; fi
    if (( REPORT_MODE )); then draw_report; return; fi

    TERM_W=$(tput cols 2>/dev/null || echo 80)
    TERM_H=$(tput lines 2>/dev/null || echo 24)

    SIDEBAR_W=32
    (( TERM_W < 60 )) && SIDEBAR_W=0
    TREE_W=$((TERM_W - SIDEBAR_W - 1))
    (( TREE_W < 20 )) && TREE_W=20

    local out=""
    out+="$CLEAR"
    build_status_bar
    out+="$_SB"

    if (( FILTER_MODE )); then
        out+="  ${BLD}${LGR}/${RST}${BLD}${FILTER_INPUT}${RST}${DIM}█ Esc to cancel${RST}${NL}"
    fi

    build_hr
    out+="$_HR"

    local vis=$((TERM_H - 3))
    (( FILTER_MODE )) && ((vis--))
    (( vis < 1 )) && vis=1

    local max_scroll=$((RENDER_N - vis))
    (( max_scroll < 0 )) && max_scroll=0

    if (( CURSOR >= 0 )); then
        (( CURSOR < SCROLL )) && SCROLL=$CURSOR
        (( CURSOR >= SCROLL + vis )) && SCROLL=$((CURSOR - vis + 1))
    fi
    (( SCROLL > max_scroll )) && SCROLL=$max_scroll
    (( SCROLL < 0 )) && SCROLL=0

    if (( HELP_ON )); then
        draw_help "$out" "$vis"
        return
    fi

    if (( SIDEBAR_W > 0 )); then
        build_sidebar "$vis"
        local drawn=0
        local vl="${DIM}│${RST}"
        for ((idx=SCROLL; idx<RENDER_N && drawn<vis; idx++)); do
            local tl; tl=$(pad_to "${RENDER[$idx]}" "$TREE_W")
            if (( idx == CURSOR )); then
                tl="${YEL}▸${tl:7}${RST}"
            fi
            local sl="${SIDEBAR_LINES[$drawn]:-}"
            local sl_padded; sl_padded=$(pad_to "$sl" "$SIDEBAR_W")
            out+="${tl}${vl}${sl_padded}${NL}"
            ((drawn++))
        done
        for ((; drawn<vis; drawn++)); do
            local padding=""
            for _ in $(seq 1 $TREE_W); do padding+=" "; done
            local sl="${SIDEBAR_LINES[$drawn]:-}"
            local sl_padded; sl_padded=$(pad_to "$sl" "$SIDEBAR_W")
            out+="${padding}${vl}${sl_padded}${NL}"
        done
    else
        local drawn=0
        for ((idx=SCROLL; idx<RENDER_N && drawn<vis; idx++)); do
            if (( idx == CURSOR )); then
                out+="${YEL}▸${RENDER[$idx]:7}${RST}${NL}"
            else
                out+="${RENDER[$idx]}${NL}"
            fi
            ((drawn++))
        done
        for ((; drawn<vis; drawn++)); do out+="${NL}"; done
    fi

    build_hr
    out+="$_HR"

    if [[ -n "$MSG" ]]; then
        local now=$(date +%s)
        if (( now - MSG_TIME < 2 )); then
            out+="  ${BLD}${LGR}${MSG}${RST}${NL}"
        else
            MSG=""
        fi
    fi

    if (( SIDEBAR_FOCUS )); then
        out+="  ${DIM}j/k${RST} ↕ select  ${DIM}Enter${RST} confirm  ${DIM}0${RST} reset  ${DIM}Esc/b${RST} cancel${RST}${NL}"
    else
        out+="  ${DIM}j/k${RST} ↕  ${DIM}d${RST} diff  ${DIM}f${RST} files  ${DIM}y${RST} copy  ${DIM}D${RST} date  ${DIM}R${RST} report  ${DIM}/${RST} filter  ${DIM}?${RST} help  ${DIM}q${RST} quit${RST}${NL}"
    fi

    printf '%b' "$out"
}

draw_help() {
    local out="$1" vis="$2"
    local hx=$(( (TERM_W - 54) / 2 ))
    (( hx < 2 )) && hx=2
    local hpfx=""
    for _ in $(seq 1 $hx); do hpfx+=" "; done

    out+="$NL"
    out+="${hpfx}${BLD}${CYN}╔════════════════════════════════════════════════════╗${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}  ${BLD}gitscope - Interactive Git Tree Viewer${RST}          ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}╠════════════════════════════════════════════════════╣${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}  ${BLD}Navigation${RST}                                      ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LGR}j${RST} / ${LGR}↓${RST}       Move cursor down                  ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LGR}k${RST} / ${LGR}↑${RST}       Move cursor up                    ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LGR}J${RST} / ${LGR}K${RST}       Move 5 lines                     ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LGR}g${RST} / ${LGR}G${RST}       Top / Bottom                      ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LGR}PgUp/PgDn${RST}   Page up/down                      ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}╠════════════════════════════════════════════════════╣${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}  ${BLD}Actions${RST}                                          ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}Enter/o${RST}     Zoom into commit descendants      ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}d${RST}           View commit diff                  ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}f${RST}           View changed files                 ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}y${RST}           Copy commit hash                   ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}/${RST}           Filter commits (regex)            ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}D${RST}           Toggle last-7-day date filter      ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}R${RST}           Report: files by author            ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}r${RST}           Refresh data                      ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}╠════════════════════════════════════════════════════╣${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}  ${BLD}Display${RST}                                          ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}a${RST}           Toggle all branches                ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}m${RST}           Toggle commit metadata             ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}c${RST}           Toggle compact mode                ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LYL}+${RST} / ${LYL}-${RST}         ±10 commits                       ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}╠════════════════════════════════════════════════════╣${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}  ${BLD}Sidebar${RST}                                           ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LBL}b${RST}           Focus branch picker (sidebar)     ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LBL}0${RST}           Reset all filters                 ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LBL}ESC${RST}          Clear zoom filter                  ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}╠════════════════════════════════════════════════════╣${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LRE}?${RST}           Toggle this help                  ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}║${RST}    ${LRE}q${RST} / ${LRE}Ctrl-C${RST}    Quit                              ${BLD}${CYN}║${RST}$NL"
    out+="${hpfx}${BLD}${CYN}╚════════════════════════════════════════════════════╝${RST}$NL"

    local remain=$((vis - 22))
    (( remain < 0 )) && remain=0
    for _ in $(seq 1 $remain); do out+="$NL"; done

    local hr2=""
    for _ in $(seq 1 $TERM_W); do hr2+="─"; done
    out+="${DIM}${hr2}${RST}$NL"
    out+="  ${DIM}?${RST} close  ${DIM}q${RST} quit${RST}$NL"

    printf '%b' "$out"
}

# ═══════════════════════════════════════════════════════════════════════════
# Input
# ═══════════════════════════════════════════════════════════════════════════
LAST_KEY=""
read_key() {
    local key=""
    if IFS= read -rsn1 -t 0.033 key 2>/dev/null; then
        if [[ -z "$key" ]]; then
            LAST_KEY=$'\x0a'
            return
        fi
    else
        LAST_KEY=""
        return
    fi

    if [[ "$key" == $'\x1b' ]]; then
        local s1="" s2=""
        IFS= read -rsn1 -t 0.05 s1 2>/dev/null || true
        if [[ -z "$s1" ]]; then
            LAST_KEY="ESC"
            return
        fi
        [[ "$s1" != '[' ]] && { LAST_KEY=""; return; }
        IFS= read -rsn1 -t 0.05 s2 2>/dev/null || true
        case "$s2" in
            A) LAST_KEY="UP" ;;
            B) LAST_KEY="DOWN" ;;
            5) LAST_KEY="PAGEUP" ;;
            6) LAST_KEY="PAGEDOWN" ;;
            H) LAST_KEY="HOME" ;;
            F) LAST_KEY="END" ;;
            *) LAST_KEY="" ;;
        esac
        return
    fi

    LAST_KEY="$key"
}

# ═══════════════════════════════════════════════════════════════════════════
# Main
# ═══════════════════════════════════════════════════════════════════════════
init_term

while true; do
    if (( REFRESH )); then
        fetch_data
        [[ -n "$DESCENDANT_FILTER" ]] && build_desc_set
        pre_render
        DIRTY=1
        REFRESH=0
        (( CURSOR < 0 )) && CURSOR=0
        (( CURSOR >= RENDER_N )) && CURSOR=$((RENDER_N-1))
    fi

    if (( DIRTY )); then
        draw
        DIRTY=0
    fi

    read_key
    key="$LAST_KEY"

    if (( FILTER_MODE )); then
        case "$key" in
            $'\x0a'|$'\x0d') FILTER_MODE=0; DIRTY=1 ;;
            'ESC')           FILTER_INPUT=""; FILTER_TEXT=""
                             FILTER_MODE=0; pre_render; DIRTY=1 ;;
            $'\x7f'|$'\x08') FILTER_INPUT="${FILTER_INPUT%?}"
                             FILTER_TEXT="$FILTER_INPUT"
                             SCROLL=0; pre_render; DIRTY=1 ;;
            $'\x03')         break ;;
            '')              ;;
            *)               FILTER_INPUT+="$key"
                             FILTER_TEXT="$FILTER_INPUT"
                             SCROLL=0; pre_render; DIRTY=1 ;;
        esac
        continue
    fi

    if (( DIFF_MODE )); then
        case "$key" in
            'j'|'DOWN')     ((DIFF_SCROLL++)); DIRTY=1 ;;
            'k'|'UP')       ((DIFF_SCROLL > 0)) && ((DIFF_SCROLL--)); DIRTY=1 ;;
            'J')            ((DIFF_SCROLL+=5)); DIRTY=1 ;;
            'K')            ((DIFF_SCROLL > 4)) && ((DIFF_SCROLL-=5)) || DIFF_SCROLL=0; DIRTY=1 ;;
            'q'|'ESC')      DIFF_MODE=0; DIRTY=1 ;;
            $'\x03')        break ;;
            '')             ;;
        esac
        continue
    fi

    if (( FILES_MODE )); then
        case "$key" in
            'j'|'DOWN')     ((FILES_SCROLL++)); DIRTY=1 ;;
            'k'|'UP')       ((FILES_SCROLL > 0)) && ((FILES_SCROLL--)); DIRTY=1 ;;
            'J')            ((FILES_SCROLL+=5)); DIRTY=1 ;;
            'K')            ((FILES_SCROLL > 4)) && ((FILES_SCROLL-=5)) || FILES_SCROLL=0; DIRTY=1 ;;
            'q'|'ESC')      FILES_MODE=0; DIRTY=1 ;;
            $'\x03')        break ;;
            '')             ;;
        esac
        continue
    fi

    if (( REPORT_MODE )); then
        if (( REPORT_EMAIL_MODE )); then
            case "$key" in
                $'\x0a'|$'\x0d')
                    if (( ${#REPORT_AC_LIST[@]} > 0 )); then
                        REPORT_EMAIL_INPUT="${REPORT_AC_LIST[$REPORT_AC_IDX]}"
                    fi
                    REPORT_EMAIL_FILTER="$REPORT_EMAIL_INPUT"
                    REPORT_EMAIL_MODE=0; open_report; DIRTY=1 ;;
                $'\x09')
                    if (( ${#REPORT_AC_LIST[@]} == 1 )); then
                        REPORT_EMAIL_INPUT="${REPORT_AC_LIST[0]}"
                        REPORT_EMAIL_FILTER="$REPORT_EMAIL_INPUT"
                        REPORT_EMAIL_MODE=0; open_report; DIRTY=1
                    elif (( ${#REPORT_AC_LIST[@]} > 1 )); then
                        ((REPORT_AC_IDX++))
                        ((REPORT_AC_IDX >= ${#REPORT_AC_LIST[@]})) && REPORT_AC_IDX=0
                        REPORT_EMAIL_INPUT="${REPORT_AC_LIST[$REPORT_AC_IDX]}"
                    fi
                    DIRTY=1 ;;
                'ESC')           REPORT_EMAIL_INPUT=""; REPORT_EMAIL_MODE=0; DIRTY=1 ;;
                $'\x7f'|$'\x08') REPORT_EMAIL_INPUT="${REPORT_EMAIL_INPUT%?}"
                                 REPORT_AC_IDX=0
                                 DIRTY=1 ;;
                $'\x03')         break ;;
                '')              ;;
                *)               REPORT_EMAIL_INPUT+="$key"
                                 REPORT_AC_IDX=0
                                 DIRTY=1 ;;
            esac
            if (( REPORT_EMAIL_MODE )); then
                REPORT_AC_LIST=()
                if [[ -n "$REPORT_EMAIL_INPUT" ]]; then
                    mapfile -t REPORT_AC_LIST < <(
                        git log --format="%ae" 2>/dev/null | sort -u |
                        grep -i "^${REPORT_EMAIL_INPUT}" 2>/dev/null | head -5
                    )
                fi
            fi
            continue
        fi
        case "$key" in
            'j'|'DOWN')     ((REPORT_SCROLL++)); DIRTY=1 ;;
            'k'|'UP')       ((REPORT_SCROLL > 0)) && ((REPORT_SCROLL--)); DIRTY=1 ;;
            'J')            ((REPORT_SCROLL+=5)); DIRTY=1 ;;
            'K')            ((REPORT_SCROLL > 4)) && ((REPORT_SCROLL-=5)) || REPORT_SCROLL=0; DIRTY=1 ;;
            'g')            REPORT_SCROLL=0; DIRTY=1 ;;
            'G')            REPORT_SCROLL=99999; DIRTY=1 ;;
            '/')
                REPORT_EMAIL_MODE=1; REPORT_EMAIL_INPUT=""; DIRTY=1 ;;
            't')
                if [[ "$REPORT_SORT" == "name" ]]; then
                    REPORT_SORT="date"
                else
                    REPORT_SORT="name"
                fi
                open_report; DIRTY=1 ;;
            'b')
                REPORT_MODE=0; REPORT_EMAIL_FILTER=""
                SIDEBAR_FOCUS=1; BRANCH_IDX=0; DIRTY=1 ;;
            'q'|'ESC')      REPORT_MODE=0; REPORT_EMAIL_FILTER=""; DIRTY=1 ;;
            $'\x03')        break ;;
            '')             ;;
        esac
        continue
    fi

    if (( SIDEBAR_FOCUS )); then
        case "$key" in
            'j'|'DOWN')     ((BRANCH_IDX++)); ((BRANCH_IDX >= ${#BRANCHES[@]})) && BRANCH_IDX=$((${#BRANCHES[@]}-1)); DIRTY=1 ;;
            'k'|'UP')       ((BRANCH_IDX > 0)) && ((BRANCH_IDX--)); DIRTY=1 ;;
            'g')            BRANCH_IDX=0; DIRTY=1 ;;
            'G')            BRANCH_IDX=$((${#BRANCHES[@]}-1)); DIRTY=1 ;;
            $'\x0a'|$'\x0d') BRANCH_FILTER="${BRANCHES[$BRANCH_IDX]}"
                             SIDEBAR_FOCUS=0; MODE="tree"; REFRESH=1 ;;
            '0')            BRANCH_FILTER=""; SIDEBAR_FOCUS=0; MODE="tree"; REFRESH=1 ;;
            'ESC'|'b'|'q')  SIDEBAR_FOCUS=0; DIRTY=1 ;;
            '')             ;;
        esac
        continue
    fi

    case "$key" in
        $'\x03'|'q'|'Q')  break ;;
        'j'|'DOWN')       ci="${RENDER_TO_COMMIT[$CURSOR]:-}"; n=$((CURSOR+1))
                          while (( n < RENDER_N )); do
                              [[ "${RENDER_TO_COMMIT[$n]:-}" != "$ci" ]] && break
                              ((n++))
                          done
                          (( n < RENDER_N )) && CURSOR=$n
                          DIRTY=1 ;;
        'k'|'UP')         ci="${RENDER_TO_COMMIT[$CURSOR]:-}"; n=$((CURSOR-1))
                          while (( n >= 0 )); do
                              [[ "${RENDER_TO_COMMIT[$n]:-}" != "$ci" ]] && break
                              ((n--))
                          done
                          (( n >= 0 )) && CURSOR=$n
                          DIRTY=1 ;;
        'J')              cnt=0; ci="${RENDER_TO_COMMIT[$CURSOR]:-}"; n=$CURSOR
                          while (( cnt < 5 && n < RENDER_N-1 )); do
                              ((n++))
                              [[ "${RENDER_TO_COMMIT[$n]:-}" != "$ci" ]] && { ci="${RENDER_TO_COMMIT[$n]}"; ((cnt++)); }
                          done
                          CURSOR=$n; DIRTY=1 ;;
        'K')              cnt=0; ci="${RENDER_TO_COMMIT[$CURSOR]:-}"; n=$CURSOR
                          while (( cnt < 5 && n > 0 )); do
                              ((n--))
                              [[ "${RENDER_TO_COMMIT[$n]:-}" != "$ci" ]] && { ci="${RENDER_TO_COMMIT[$n]}"; ((cnt++)); }
                          done
                          CURSOR=$n; DIRTY=1 ;;
        'g')              CURSOR=0; DIRTY=1 ;;
        'G')              CURSOR=$((RENDER_N-1)); DIRTY=1 ;;
        'PAGEUP')         ((CURSOR -= TERM_H - 4)); (( CURSOR < 0 )) && CURSOR=0; DIRTY=1 ;;
        'PAGEDOWN')       ((CURSOR += TERM_H - 4)); ((CURSOR > RENDER_N-1)) && CURSOR=$((RENDER_N-1)); DIRTY=1 ;;
        'HOME')           CURSOR=0; DIRTY=1 ;;
        'END')            CURSOR=$((RENDER_N-1)); DIRTY=1 ;;
        'a')              SHOW_ALL=$(( 1 - SHOW_ALL )); BRANCH_FILTER=""; FILTER_TEXT=""
                          DESCENDANT_FILTER=""; REFRESH=1 ;;
        'm')              SHOW_META=$(( 1 - SHOW_META )); pre_render; DIRTY=1 ;;
        'c')              COMPACT=$(( 1 - COMPACT )); pre_render; DIRTY=1 ;;
        '+')              ((COUNT += 10)); ((COUNT > 200)) && COUNT=200; REFRESH=1 ;;
        '-')              ((COUNT > 10)) && ((COUNT -= 10)); REFRESH=1 ;;
        'b')              SIDEBAR_FOCUS=1; BRANCH_IDX=0; DIRTY=1 ;;
        '0')              BRANCH_FILTER=""; FILTER_TEXT=""; DESCENDANT_FILTER=""
                          DATE_FROM=""; DATE_TO=""; REFRESH=1 ;;
        '/')              FILTER_MODE=1; FILTER_INPUT=""; DIRTY=1 ;;
        'o'|$'\x0a'|$'\x0d')
            if (( CURSOR >= 0 && CURSOR < RENDER_N )); then
                ci=${RENDER_TO_COMMIT[$CURSOR]}
                if [[ -n "$ci" ]]; then
                    DESCENDANT_FILTER="${H[$ci]}"
                    build_desc_set
                    CURSOR=0
                    pre_render
                    DIRTY=1
                fi
            fi
            ;;
        'ESC')
            if [[ -n "$DESCENDANT_FILTER" ]]; then
                DESCENDANT_FILTER=""; CURSOR=0; pre_render; DIRTY=1
            elif [[ -n "$DATE_FROM" || -n "$DATE_TO" ]]; then
                DATE_FROM=""; DATE_TO=""; CURSOR=0; pre_render; DIRTY=1
            fi
            ;;
        'd')
            if (( CURSOR >= 0 )); then
                ci=${RENDER_TO_COMMIT[$CURSOR]:-}
                [[ -n "$ci" ]] && open_diff "$ci"
            fi
            ;;
        'f')
            if (( CURSOR >= 0 )); then
                ci=${RENDER_TO_COMMIT[$CURSOR]:-}
                [[ -n "$ci" ]] && open_files "$ci"
            fi
            ;;
        'y')
            if (( CURSOR >= 0 )); then
                ci=${RENDER_TO_COMMIT[$CURSOR]:-}
                if [[ -n "$ci" && -n "${H[$ci]}" ]]; then
                    if [[ -n "$CLIPBOARD_CMD" ]]; then
                        echo -n "${H[$ci]}" | $CLIPBOARD_CMD 2>/dev/null
                        show_msg "Copied ${H[$ci]:0:7} to clipboard"
                    else
                        show_msg "No clipboard tool found"
                    fi
                fi
            fi
            ;;
        'D')
            if [[ -n "$DATE_FROM" || -n "$DATE_TO" ]]; then
                DATE_FROM=""; DATE_TO=""; CURSOR=0
                show_msg "Date filter cleared"
            else
                local today; today=$(date +%Y-%m-%d)
                local week_ago; week_ago=$(date -d "$today - 7 days" +%Y-%m-%d 2>/dev/null || date -v-7d +%Y-%m-%d 2>/dev/null || echo "")
                if [[ -n "$week_ago" ]]; then
                    DATE_FROM="$week_ago"; DATE_TO="$today"
                    show_msg "Last 7 days: $week_ago → $today"
                fi
            fi
            CURSOR=0; pre_render; DIRTY=1
            ;;
        '?')              HELP_ON=$(( 1 - HELP_ON )); DIRTY=1 ;;
        'R')              open_report ;;
        'r')              REFRESH=1 ;;
        '')               ;;
    esac
done
